{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Axiom IDE default capabilities",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "store:default",
    "shell:default",
    "shell:allow-open",
    "window-state:default"
  ]
}